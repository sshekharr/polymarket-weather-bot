{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "polymarket-weather-bot-gateway",
  "buildCommand": "echo \"Vercel deploy: API health routes only — no trading build\"",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
